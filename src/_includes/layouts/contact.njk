---
layout: base.njk
---
<section class="section section--white section--flush-top section--flush-bottom">
  <div class="container">
    <h1 class="content-blocks__heading text-uppercase">{{ page_title.heading }}</h1>
  </div>
</section>

<section class="content-blocks section section--white">
  <div class="container">
    <div class="content-blocks__grid content-blocks__grid--cols-3">
      <article class="content-blocks__block">
        <h2 class="content-blocks__block-heading">Office</h2>
        <p>{{ office.location }}</p>
        <a href="{{ office.map_url }}" class="btn btn--outline">Map</a>
      </article>
      <article class="content-blocks__block">
        <h2 class="content-blocks__block-heading">Phone</h2>
        <p><a href="{{ office.phone_href }}">{{ office.phone }}</a></p>
        <a href="{{ office.phone_href }}" class="btn btn--outline">Call Now</a>
      </article>
      <article class="content-blocks__block">
        <h2 class="content-blocks__block-heading">Email</h2>
        <p><a href="{{ office.email_href }}">{{ office.email }}</a></p>
        <a href="{{ office.email_href }}" class="btn btn--outline">Email</a>
      </article>
    </div>
  </div>
</section>

<section class="section section--blue">
  <div class="container">
    <div class="page-intro">
      <h2 class="cta-block__heading">{{ intro_heading }}</h2>
      {% for paragraph in intro_body %}
      <p>{{ paragraph }}</p>
      {% endfor %}
    </div>
  </div>
</section>

<section class="contact-form-section">
  <div class="container">
    <h2 class="content-blocks__heading text-uppercase">{{ contact_section.heading }}</h2>
    <div role="status" aria-live="polite" aria-atomic="true"></div>
    <form class="contact-form" action="https://api.web3forms.com/submit" method="post" novalidate>
      <input type="hidden" name="access_key" value="{{ env.web3formsKey }}" />
      <input type="hidden" name="subject" value="New contact form submission — {{ site.name }}" />
      <input type="hidden" name="redirect" value="{{ site.url }}/contact-success/" />
      <input type="hidden" name="from_name" value="{{ site.name }}" />
      <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" aria-hidden="true" />
      <h3 class="section-heading">{{ form.heading }}</h3>

      <p class="form-required-note">All fields marked with * are required.</p>

      <div class="form-field">
        <label class="form-label" for="org-name">Organization Name <span aria-hidden="true">*</span></label>
        <input class="form-input" type="text" id="org-name" name="org_name" required autocomplete="organization" aria-describedby="org-name-error" />
        <p class="form-error" id="org-name-error"></p>
      </div>

      <div class="form-field">
        <label class="form-label" for="your-name">Your Name <span aria-hidden="true">*</span></label>
        <input class="form-input" type="text" id="your-name" name="your_name" required autocomplete="name" aria-describedby="your-name-error" />
        <p class="form-error" id="your-name-error"></p>
      </div>

      <div class="form-field">
        <label class="form-label" for="email">Email <span aria-hidden="true">*</span></label>
        <input class="form-input" type="email" id="email" name="replyto" required autocomplete="email" aria-describedby="email-error" />
        <p class="form-error" id="email-error"></p>
      </div>

      <div class="form-field">
        <label class="form-label" for="phone">Phone Number <span aria-hidden="true">*</span></label>
        <input class="form-input" type="tel" id="phone" name="phone" required autocomplete="tel" aria-describedby="phone-error" />
        <p class="form-error" id="phone-error"></p>
      </div>

      <div class="form-field">
        <label class="form-label" for="location">Location (City/State) <span aria-hidden="true">*</span></label>
        <input class="form-input" type="text" id="location" name="location" required aria-describedby="location-error" />
        <p class="form-error" id="location-error"></p>
      </div>

      <div class="form-field">
        <label class="form-label" for="org-type">Type of Organization <span aria-hidden="true">*</span></label>
        <textarea class="form-textarea" id="org-type" name="org_type" rows="4" required placeholder="School District / Company / Nonprofit / Higher Ed / Other" aria-describedby="org-type-error"></textarea>
        <p class="form-error" id="org-type-error"></p>
      </div>

      <div class="form-field">
        <label class="form-label" for="service-interest">Service Interest <span aria-hidden="true">*</span></label>
        <textarea class="form-textarea" id="service-interest" name="service_interest" rows="4" required placeholder="Accessibility Evaluation / Website Remediation / Training &amp; Webinars / VPAT Writing / Other" aria-describedby="service-interest-error"></textarea>
        <p class="form-error" id="service-interest-error"></p>
      </div>

      <div class="form-field">
        <label class="form-label" for="description">Brief Description of Need <span aria-hidden="true">*</span></label>
        <textarea class="form-textarea" id="description" name="description" rows="4" required aria-describedby="description-error"></textarea>
        <p class="form-error" id="description-error"></p>
      </div>

      <div class="form-field">
        <label class="form-label" for="contact-method">Preferred Contact Method <span aria-hidden="true">*</span></label>
        <select class="form-input" id="contact-method" name="contact_method" required aria-describedby="contact-method-error">
          <option value="">Select a method</option>
          <option value="Email">Email</option>
          <option value="Phone">Phone</option>
          <option value="Either">Either</option>
        </select>
        <p class="form-error" id="contact-method-error"></p>
      </div>
  
      <button type="submit" class="btn btn--outline">Send</button>

      <p class="form-privacy">{{ form.privacy_text }}</p>
    </form>
  </div>
</section>

<section class="section section--white text-center">
<div class="container">
  <hr class="divider">
</div>
  <div class="container contact-office">
    <h2 class="section-heading">{{ office.heading }}</h2>
    <p><a href="{{ office.phone_href }}">{{ office.phone }}</a>
    <br /><a href="{{ office.email_href }}">{{ office.email }}</a></p>
  </div>
</section>

{% include "partials/cta.njk" %}
