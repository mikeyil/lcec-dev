<meta charset="utf-8" />
{% if site.gscVerificationId %}<meta name="google-site-verification" content="{{ site.gscVerificationId }}" />{% endif %}
<meta name="viewport" content="width=device-width, initial-scale=1" />
{% set _pageTitle = page.url | pathToTitle %}
<title>{% if _pageTitle %}{{ _pageTitle }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
<meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}" />
<meta name="author" content="{{ site.name }}" />
<meta name="referrer" content="strict-origin-when-cross-origin" />
{% if page.url == "/contact-success/" %}<meta name="robots" content="noindex, nofollow" />{% endif %}
<link rel="canonical" href="{{ site.url }}{{ page.url }}" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="{{ site.name }}" />
<meta property="og:title" content="{% if _pageTitle %}{{ _pageTitle }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}" />
<meta property="og:description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}" />
<meta property="og:url" content="{{ site.url }}{{ page.url }}" />
<meta property="og:image" content="{{ site.url }}{% if og_image %}{{ og_image }}{% else %}/img/og-image.png{% endif %}" />
<meta property="og:image:alt" content="{% if og_image_alt %}{{ og_image_alt }}{% else %}{{ site.name }}{% endif %}" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{% if _pageTitle %}{{ _pageTitle }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}" />
<meta name="twitter:description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}" />
<meta name="twitter:image" content="{{ site.url }}{% if og_image %}{{ og_image }}{% else %}/img/og-image.png{% endif %}" />
<meta name="twitter:image:alt" content="{% if og_image_alt %}{{ og_image_alt }}{% else %}{{ site.name }}{% endif %}" />

<!-- JSON-LD: Business schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "{{ site.name }}",
  "url": "{{ site.url }}",
  "telephone": "{{ site.phone }}",
  "email": "{{ site.email }}",
  "description": "{{ site.description }}",
  "foundingDate": "{{ site.foundingDate }}",
  "founder": {
    "@type": "Person",
    "name": "{{ site.founder }}"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "{{ site.city }}",
    "addressRegion": "{{ site.state }}",
    "addressCountry": "{{ site.country }}"
  },
  "sameAs": [
    "{{ site.linkedinUrl }}"{% if site.googleBusinessUrl %},
    "{{ site.googleBusinessUrl }}"{% endif %}
  ],
  "areaServed": {
    "@type": "Country",
    "name": "United States"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Accessibility Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Digital Accessibility Audits" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "VPAT Writing" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "PDF and Document Remediation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Remediation Roadmaps" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Accessibility Training and Webinars" } }
    ]
  }
}
</script>
<!-- JSON-LD: Person (Laura Cantagallo) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "{{ site.founder }}",
  "jobTitle": "Accessibility Consultant",
  "url": "{{ site.founderUrl }}",
  "worksFor": {
    "@type": "ProfessionalService",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}"
  }
}
</script>
{% if page.url and page.url !== "/" %}
<!-- JSON-LD: Breadcrumbs -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" },
    { "@type": "ListItem", "position": 2, "name": "{{ page.url | pathToTitle }}", "item": "{{ site.url }}{{ page.url }}" }
  ]
}
</script>
{% endif %}
{% if services %}
<!-- JSON-LD: Services -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "{{ services_heading }}",
  "itemListElement": [
    {% for service in services %}
    { "@type": "ListItem", "position": {{ loop.index }}, "item": { "@type": "Service", "name": "{{ service.heading }}", "description": "{{ service.description }}", "provider": { "@type": "ProfessionalService", "name": "{{ site.name }}" } } }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

<link rel="manifest" href="{{ '/manifest.webmanifest' | url }}" />
<link rel="icon" type="image/svg+xml" href="{{ '/img/favicon.svg' | url }}" />
<link rel="apple-touch-icon" sizes="180x180" href="{{ '/img/icon-192.png' | url }}" />
<meta name="theme-color" content="#556b2f" />
<link rel="preconnect" href="https://api.web3forms.com" />
<link rel="dns-prefetch" href="https://www.linkedin.com" />
<link rel="preload" href="{{ '/fonts/lato-400.woff2' | url }}" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="{{ '/fonts/lato-700.woff2' | url }}" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="{{ '/css/main.css' | url }}" as="style" />
<style>
  @font-face {
    font-family: 'Lato';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('{{ "/fonts/lato-400.woff2" | url }}') format('woff2');
  }
  @font-face {
    font-family: 'Lato';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('{{ "/fonts/lato-700.woff2" | url }}') format('woff2');
  }
</style>
{% if site.gaId %}<link rel="preconnect" href="https://www.googletagmanager.com" />{% endif %}
<link rel="stylesheet" href="{{ '/css/main.css' | url }}" />
