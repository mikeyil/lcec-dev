<footer class="site-footer">
  <button
    class="footer-nav-toggle"
    aria-expanded="true"
    aria-controls="footer-nav-content"
    aria-label="Collapse footer navigation">
    <svg viewBox="7.5 9.5 9 5" fill="currentColor" width="12" height="7" aria-hidden="true">
      <polygon points="12,14 8,10 16,10"/>
    </svg>
  </button>
  <div class="container">
    <div class="footer-inner">
      <nav class="footer-nav">
        <ul class="footer-nav__list">
          {% for link in navigation.links %}
            {% if not link.hideFromFooter %}
              {% if link.dropdown %}
                {% for child in link.children %}
                <li class="footer-nav__item">
                  <a href="{{ child.url | url }}" class="footer-nav__link">{{ child.text }}</a>
                </li>
                {% endfor %}
              {% elif link.external %}
              <li class="footer-nav__item">
                <a href="{{ link.url }}" class="footer-nav__link" target="_blank" rel="noopener noreferrer">{{ link.text }}</a>
              </li>
              {% else %}
              <li class="footer-nav__item">
                <a href="{{ link.url | url }}" class="footer-nav__link">{{ link.text }}</a>
              </li>
              {% endif %}
            {% endif %}
          {% endfor %}
        </ul>
      </nav>
      <hr class="divider">
      <p class="footer-brand"><a href="{{ '/' | url }}">{{ site.name }}</a></p>
      <p class="footer-phone"><a href="{{ office.phone_href }}">{{ office.phone }}</a></p>
      <p class="footer-copy text-uppercase">Copyright &copy; 2026 {{ site.name }} &mdash; All Rights Reserved.</p>
    </div>
  </div>
</footer>
